{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "ignoreDeprecations": "6.0", // This silences the deprecation warning
    "baseUrl": ".", // Optional if you're using paths
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.js"]
}
